
unit ObispoCadena;

interface
uses
  System.Classes, Mate;
type

  Cadena=class
    private
      longitud:word;
      caracteres:array[1..2048] of char;
    public

      constructor Create;
      procedure setStr(s:string);
      procedure Anadir(c:char);
      procedure Modificar(pos:word;c:char);
      procedure Insertar(pos:word;c:char);
      procedure Eliminar(pos:integer);
      procedure EliminarRepetidos;

      function getLong:word;
      function getChar(pos:word):char;
      function getStr:string;
      function BuscarChar(c:char):integer;
      function FrecuenciaChar(c:char):integer;
      function MayorFrec:char;

  end;

implementation

constructor Cadena.Create;
begin
  longitud:=0;
end;

procedure Cadena.setStr(s: string);
var
  i:word;
begin
  longitud:=Length(s);
  for i := 1 to longitud do
    caracteres[i]:=s[i];
end;

procedure Cadena.Anadir(c: char);
begin
  longitud:=longitud+1;
  caracteres[longitud]:=c;
end;

procedure Cadena.Modificar(pos: word;c: char);
begin
  caracteres[pos]:=c;
end;

procedure Cadena.Insertar(pos: word; c: Char);
var
  i:integer;
begin
  longitud:=longitud+1;
  i:=longitud;
  While i>pos do
  begin
    caracteres[i]:=caracteres[i-1];
    i:=i-1;
  end;
  caracteres[pos]:=c;
end;

// No sabes Programar
procedure Cadena.Eliminar(pos: Integer);
var
  i: Integer;
begin
  if (pos>0) and (pos<=longitud) then
  begin
  for i := pos to longitud-1 do
    caracteres[i]:=caracteres[i+1];
  longitud:=longitud-1;
  end
  // else raise Exception.Create('Posicion invalida');

end;

procedure Cadena.EliminarRepetidos;
var
  i: Integer;
begin
  for i := 1 to longitud do
    if FrecuenciaChar(caracteres[i])>1 then
      Eliminar(i);
    else
      i++;
end;

// ---------- Funciones ----------

function Cadena.getLong: Word;
begin
  getLong:=longitud;
end;

function Cadena.getChar(pos: Word): Char;
begin
  getChar:=caracteres[pos];
end;

function Cadena.getStr: string;
var
  s:string;
  i: Integer;
begin
  s:='';
  for i := 1 to longitud do
    s:=s+caracteres[i];
  getStr:=s;
end;

function Cadena.BuscarChar(c:char):integer;
var
  i,pos: Integer;
begin
  i:=1;
  pos:=0;
  while (i<=longitud) and (pos=0) do
  begin
    if caracteres[i]=c then
      pos:=i;
    i:=i+1;
  end;
  BuscarChar:=pos;
end;

function Cadena.FrecuenciaChar(c:Char):integer;
var
  i,frec:integer;
begin
  i:=1;
  frec:=0;
  for i := 1 to longitud do
    if caracteres[i]=c then
      frec:=frec+1;
  FrecuenciaChar:=frec;
end;

function Cadena.MayorFrec:Char;
var
  i,Mayor: Integer;
  buscado:char;
begin
  Mayor:=0;
  for i := 1 to longitud do
    if FrecuenciaChar(caracteres[i])>Mayor then
    begin
      Mayor:=FrecuenciaChar(caracteres[i]);
      buscado:=caracteres[i];
    end;
  MayorFrec:=buscado;
end;

end.
